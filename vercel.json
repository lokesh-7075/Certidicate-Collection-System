{
  "version": 2,
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api"
    },
    {
      "source": "/applications(.*)",
      "destination": "/api"
    },
    {
      "source": "/notifications(.*)",
      "destination": "/api"
    },
    {
      "source": "/faculty/profile",
      "destination": "/api"
    },
    {
      "source": "/health",
      "destination": "/api"
    },
    {
      "source": "/((?!api|assets|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
